# Cloudflare Pages response headers — applied automatically on deploy.
# (GitHub Pages ignores this file; it only takes effect once the site is
#  served from Cloudflare Pages.)

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://api.web3forms.com; form-action 'self' https://api.web3forms.com; frame-ancestors 'none'; base-uri 'self'; object-src 'none'

# NOTE: when the "Book a Consultation" page embeds Microsoft Bookings, the iframe
# host must be allowed in the CSP ABOVE (global) — add:
#   frame-src https://outlook.office365.com https://outlook.office.com
# Do NOT try to loosen CSP for just /book* via a per-path block: Cloudflare Pages
# sends BOTH the matching headers and the browser enforces the most-restrictive
# intersection, so a per-path frame-src would still be blocked by the global one.
