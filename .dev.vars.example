# Copy this file to `.dev.vars` (gitignored) and fill in your Supabase project values.
# Find these in the Supabase dashboard → Project Settings → API.

# Project URL, e.g. https://abcdefghijklmno.supabase.co
SUPABASE_URL=

# Publishable / anon key (safe to use from the server with RLS enforced).
SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Bypasses Row Level Security. Never send to the
# browser or commit it. Used for provisioning customer rows and webhook fulfillment.
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (use TEST-mode keys: sk_test_... ) ──────────────────────────
# Secret key — SERVER ONLY. Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=

# Webhook signing secret. For local dev, run:
#   stripe listen --forward-to localhost:8787/api/stripe/webhook
# and copy the printed "whsec_..." value here. In production, use the secret
# from the webhook endpoint you create in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=
